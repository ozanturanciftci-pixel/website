---
import { type Lang, OFFICE_INFO, SITE_CONTENT, buildLangPath } from '@/content/site';

const { lang } = Astro.props as { lang: Lang };
const t = SITE_CONTENT[lang];
---

<footer class="border-t border-white/60 bg-white/70 py-12 backdrop-blur-xl">
  <div class="section-wrap grid gap-8 md:grid-cols-3">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Turançiftçi Law Firm</p>
      <p class="mt-3 text-sm text-slate-700">{t.hero.description}</p>
    </div>

    <div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Offices</p>
      <p class="mt-3 text-sm text-slate-700">
        <strong>{OFFICE_INFO.istanbul.label}:</strong> {OFFICE_INFO.istanbul.address}
      </p>
      <p class="mt-3 text-sm text-slate-700">
        <strong>{OFFICE_INFO.madrid.label}:</strong> {OFFICE_INFO.madrid.address}
      </p>
    </div>

    <div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Contact</p>
      <a href={`tel:${OFFICE_INFO.phone}`} class="mt-3 block text-sm text-slate-700 hover:text-slate-900">{OFFICE_INFO.phone}</a>
      <a href={`mailto:${OFFICE_INFO.email}`} class="mt-2 block text-sm text-slate-700 hover:text-slate-900">{OFFICE_INFO.email}</a>
      <a href={OFFICE_INFO.linkedin} target="_blank" rel="noreferrer" class="mt-2 block text-sm text-brand-700 hover:text-brand-900">
        LinkedIn
      </a>
    </div>
  </div>

  <div class="section-wrap mt-8 flex flex-wrap items-center gap-4 border-t border-slate-200 pt-6 text-xs text-slate-500">
    <a href={buildLangPath(lang, '/kvkk')}>{t.nav.kvkk}</a>
    <a href={buildLangPath(lang, '/privacy')}>{t.nav.privacy}</a>
    <a href={buildLangPath(lang, '/cookies')}>{t.nav.cookies}</a>
    <span class="ml-auto">© {new Date().getFullYear()} Turançiftçi Law Firm</span>
  </div>
</footer>
