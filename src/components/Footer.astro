---
import { type Lang, buildLangPath } from '@/content/site';

const { lang, path = '' } = Astro.props as { lang: Lang; path?: string };
---

<footer class="mt-0 bg-transparent pb-6 pt-2">
  <div class="mx-auto w-full max-w-[98.5%] rounded-[0_0_24px_24px] border border-[#d9d1c5] border-t-0 bg-[#ddd3c4] px-8 py-8 md:px-14">
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <div class="space-y-4">
        <div class="flex items-center gap-5 text-[1.05rem] font-semibold text-[#2f384a]">
          <a href={buildLangPath('en', path)} class={lang === 'en' ? 'underline underline-offset-4' : 'opacity-85 hover:opacity-100'}>
            <span class="mr-1">🇬🇧</span>EN
          </a>
          <a href={buildLangPath('tr', path)} class={lang === 'tr' ? 'underline underline-offset-4' : 'opacity-85 hover:opacity-100'}>
            <span class="mr-1">🇹🇷</span>TR
          </a>
          <a href={buildLangPath('es', path)} class={lang === 'es' ? 'underline underline-offset-4' : 'opacity-85 hover:opacity-100'}>
            <span class="mr-1">🇪🇸</span>ES
          </a>
        </div>

        <div class="text-[1.05rem] text-[#3e4758]">
          <a href={buildLangPath(lang, '/cookies')} class="hover:text-[#2d3547]">Cookie Preferences</a>
          <span class="mx-2 opacity-55">|</span>
          <a href={buildLangPath(lang, '/privacy')} class="hover:text-[#2d3547]">Terms and Conditions</a>
        </div>
      </div>

      <p class="text-[1.03rem] text-[#7b7f87]">© Turançiftçi {new Date().getFullYear()}. All rights reserved.</p>
    </div>
  </div>
</footer>
