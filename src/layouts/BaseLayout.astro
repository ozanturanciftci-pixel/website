---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { LANGS, type Lang, SITE_CONTENT, buildLangPath } from '@/content/site';
import '@/styles/global.css';

type Props = {
  lang: Lang;
  title?: string;
  description?: string;
  path?: string;
  noIndex?: boolean;
  structuredData?: Record<string, unknown>;
};

const { lang, title, description, path = '', noIndex = false, structuredData } = Astro.props;
const content = SITE_CONTENT[lang];
const isHome = path === '/' || path === '';
const pageTitle = title ? `${title} | ${content.seo.siteName}` : content.seo.defaultTitle;
const pageDescription = description ?? content.seo.defaultDescription;
const siteUrl = Astro.site?.toString() ?? process.env.PUBLIC_SITE_URL ?? 'http://localhost:4321';
const canonical = new URL(buildLangPath(lang, path), siteUrl).toString();
const alternates = LANGS.map((entry) => ({ lang: entry, href: new URL(buildLangPath(entry, path), siteUrl).toString() }));
---

<!doctype html>
<html lang={lang} class={isHome ? 'home-scroll-snap' : ''}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={noIndex ? 'noindex,nofollow' : 'index,follow'} />
    <link rel="canonical" href={canonical} />

    {alternates.map((alt) => <link rel="alternate" hreflang={alt.lang} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(buildLangPath('tr', path), siteUrl).toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={content.seo.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    )}

    <ClientRouter />
  </head>
  <body>
    <Header lang={lang} path={path} />
    <main class={`page-enter ${isHome ? 'pb-0' : 'pb-20'}`}>
      <slot />
    </main>
    {!isHome && <Footer lang={lang} path={path} />}
  </body>
</html>
