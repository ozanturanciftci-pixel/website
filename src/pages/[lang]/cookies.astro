---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Lang, SITE_CONTENT, isLang } from '@/content/site';

const langParam = Astro.params.lang;
if (!langParam || !isLang(langParam)) return Astro.redirect('/tr');
const lang = langParam as Lang;
const legal = SITE_CONTENT[lang].legal;
---

<BaseLayout lang={lang} path="/cookies" title={legal.cookiesTitle}>
  <section class="section-wrap pt-16">
    <article class="glass-card rounded-[2rem] p-10">
      <h1 class="text-4xl text-slate-900">{legal.cookiesTitle}</h1>
      <p class="mt-6 text-base leading-8 text-slate-700">{legal.cookiesBody}</p>
    </article>
  </section>
</BaseLayout>
