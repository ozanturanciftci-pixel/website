---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  type Lang,
  PRACTICE_ORDER,
  SITE_CONTENT,
  OFFICE_INFO,
  buildLangPath,
  isLang
} from '@/content/site';

const langParam = Astro.params.lang;
if (!langParam || !isLang(langParam)) {
  return Astro.redirect('/tr');
}

const lang = langParam as Lang;
const t = SITE_CONTENT[lang];
const istanbulMapQuery = encodeURIComponent('Mayısgülü Sokak No:8 Daire:8 Kadıköy İstanbul');
const istanbulMapEmbedUrl = `https://www.google.com/maps?q=${istanbulMapQuery}&output=embed`;
const istanbulMapOpenUrl = `https://www.google.com/maps/search/?api=1&query=${istanbulMapQuery}`;
const heroCopy: Record<Lang, { kicker: string; title: string; subtitle: string }> = {
  tr: {
    kicker: 'Turançiftçi Hukuk Bürosu',
    title: 'Gücü Hukukta.\nNetlik Stratejide.',
    subtitle: 'Vergi, şirketler ve yabancılar hukukunda sonuç odaklı, uluslararası erişilebilir hukuki danışmanlık.'
  },
  en: {
    kicker: 'Turançiftçi Law Firm',
    title: 'Strength in Law.\nClarity in Strategy.',
    subtitle: 'Result-oriented legal counsel in tax, corporate and immigration law with international accessibility.'
  },
  es: {
    kicker: 'Bufete Turançiftçi',
    title: 'Fuerza en Derecho.\nClaridad en Estrategia.',
    subtitle: 'Asesoria legal orientada a resultados en derecho fiscal, societario y migratorio.'
  }
};

const uiCopy: Record<
  Lang,
  {
    heroReach: string;
    aboutKicker: string;
    practicesKicker: string;
    practicesHeading: string;
    practicesLead: string;
    practicesHeadLine1: string;
    practicesHeadLine2: string;
    practicesHeadCta: string;
    contactTitle: string;
    contactSubtitle: string;
    addressTitle: string;
    otherContactTitle: string;
    openMap: string;
    newsletterLabel: string;
    newsletterTextLine1: string;
    newsletterTextLine2: string;
    firstName: string;
    lastName: string;
    emailLabel: string;
    phoneLabel: string;
    subscribe: string;
  }
> = {
  tr: {
    heroReach: 'Hemen Ulaşın',
    aboutKicker: 'Hakkında',
    practicesKicker: 'Faaliyet Alanları',
    practicesHeading: 'Uzmanlık ve Çözümler',
    practicesLead: 'Vergi hukuku, şirketler hukuku ve yabancılar hukuku alanlarında odaklı temsil ve stratejik danışmanlık.',
    practicesHeadLine1: 'Faaliyet alanlarımızın sunduğu',
    practicesHeadLine2: 'stratejik avantajları keşfedin.',
    practicesHeadCta: 'Hemen Ulaşın',
    contactTitle: 'Bize Ulaşın',
    contactSubtitle: 'Hukuki ihtiyacınızı kısaca paylaşın; en uygun yol haritası için sizinle iletişime geçelim.',
    addressTitle: 'Adres',
    otherContactTitle: 'Diğer İletişim Bilgileri',
    openMap: 'Haritada Aç',
    newsletterLabel: 'Bülten',
    newsletterTextLine1: 'Önemli gelişmelerden haberdar olmak için',
    newsletterTextLine2: 'bültenimize abone olabilirsiniz.',
    firstName: 'İsim',
    lastName: 'Soyisim',
    emailLabel: 'E-posta',
    phoneLabel: 'Telefon',
    subscribe: 'Abone Ol'
  },
  en: {
    heroReach: 'Reach Us',
    aboutKicker: 'About',
    practicesKicker: 'Practice Areas',
    practicesHeading: 'Expertise and Solutions',
    practicesLead: 'Focused representation and strategic legal counsel in tax law, corporate law and immigration law.',
    practicesHeadLine1: 'Discover the strategic advantages',
    practicesHeadLine2: 'offered by our practice areas.',
    practicesHeadCta: 'Reach Us',
    contactTitle: 'Reach Us',
    contactSubtitle: 'Share your legal need briefly; we will contact you with the most suitable roadmap.',
    addressTitle: 'Address',
    otherContactTitle: 'Other Contact Details',
    openMap: 'Open in Maps',
    newsletterLabel: 'Newsletter',
    newsletterTextLine1: 'Subscribe to stay informed about',
    newsletterTextLine2: 'important legal developments.',
    firstName: 'First Name',
    lastName: 'Last Name',
    emailLabel: 'Email',
    phoneLabel: 'Phone',
    subscribe: 'Subscribe'
  },
  es: {
    heroReach: 'Contáctenos',
    aboutKicker: 'Sobre Nosotros',
    practicesKicker: 'Áreas de Práctica',
    practicesHeading: 'Experiencia y Soluciones',
    practicesLead: 'Representación enfocada y asesoría jurídica estratégica en derecho fiscal, societario y de extranjería.',
    practicesHeadLine1: 'Descubra las ventajas estratégicas',
    practicesHeadLine2: 'de nuestras áreas de práctica.',
    practicesHeadCta: 'Contáctenos',
    contactTitle: 'Contáctenos',
    contactSubtitle: 'Comparta brevemente su necesidad legal; le contactaremos con la hoja de ruta más adecuada.',
    addressTitle: 'Dirección',
    otherContactTitle: 'Otros Datos de Contacto',
    openMap: 'Abrir en Mapas',
    newsletterLabel: 'Boletín',
    newsletterTextLine1: 'Suscríbase para mantenerse al tanto de',
    newsletterTextLine2: 'desarrollos legales importantes.',
    firstName: 'Nombre',
    lastName: 'Apellido',
    emailLabel: 'Correo',
    phoneLabel: 'Teléfono',
    subscribe: 'Suscribirse'
  }
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Turançiftçi Law Firm',
  areaServed: ['Istanbul', 'Madrid'],
  telephone: OFFICE_INFO.phone,
  email: OFFICE_INFO.email,
  address: [OFFICE_INFO.istanbul.address, OFFICE_INFO.madrid.address],
  serviceType: [
    t.practices['tax-law'].title,
    t.practices['corporate-law'].title,
    t.practices['immigration-law'].title
  ]
};

const practiceImageBySlug: Record<string, string> = {
  'tax-law': '/assets/practice-tax.jpg',
  'corporate-law': '/assets/practice-corporate.jpg',
  'immigration-law': '/assets/practice-immigration.jpg'
};

const copy = uiCopy[lang];
---

<BaseLayout lang={lang} path="/" structuredData={structuredData}>
  <div class="relative bg-[#efe4d3]">
    <section id="hero-stage" class="sticky top-0 z-30 h-[100svh] min-h-[620px]">
      <div class="relative h-full overflow-hidden">
        <video
          id="hero-video"
          class="stage-image active pointer-events-none absolute inset-0 h-full w-full object-cover object-[center_48%]"
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        >
          <source src="/assets/hero-video.mp4#t=8" type="video/mp4" />
        </video>

        <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.52),rgba(0,0,0,0.28),rgba(0,0,0,0.48))]"></div>
        <div id="hero-copy" class="hero-copy-shell absolute inset-x-0 z-10 text-[#f8f1df]">
          <div class="grid w-full items-end gap-6 md:grid-cols-[1fr_auto] md:gap-8">
            <div class="max-w-3xl">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[#ead9b7]">{heroCopy[lang].kicker}</p>
              <h1 class="mt-3 whitespace-pre-line text-5xl leading-[0.95] text-[#fff8ea] md:text-7xl">{heroCopy[lang].title}</h1>
              <p class="mt-5 max-w-2xl text-base leading-8 text-[#f2e6cf] md:text-lg">{heroCopy[lang].subtitle}</p>
            </div>
            <a href={`mailto:${OFFICE_INFO.email}`} class="hero-contact-pill justify-self-start self-start md:justify-self-end md:self-center" aria-label={copy.heroReach}>
              <span class="hero-contact-pill-label">{copy.heroReach}</span>
              <span class="hero-contact-pill-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 6h16v12H4z"></path>
                  <path d="m4 7 8 6 8-6"></path>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="relative z-10 border-t border-[#d8d2c8] pt-12 md:pt-16">
      <section id="about" data-nav-section class="relative min-h-[88vh] scroll-mt-48 overflow-hidden bg-[#f0e7d9] py-16 md:py-20">
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(240,231,217,0.90),rgba(240,231,217,0.97))]"></div>

        <div class="section-wrap relative z-10">
          <div class="section-reveal">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#7a6e60]">{copy.aboutKicker}</p>
            <h2 class="mt-3 text-5xl leading-[0.95] text-[#2b3447] md:text-6xl" transition:name="hero">{t.about.title}</h2>
            <p class="mt-6 max-w-3xl text-lg leading-9 text-[#4c5568]">{t.about.lead}</p>

            <div class="mt-10 space-y-4 text-base leading-8 text-[#4c5568]">
              {t.about.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>

            <a href="#contact" class="mt-10 inline-flex rounded-2xl bg-[#6f7788] px-8 py-4 text-base font-bold text-white transition hover:bg-[#5f6676]">
              {t.hero.primaryCta}
            </a>
          </div>
        </div>
      </section>

      <section id="practices" data-nav-section class="section-divider relative min-h-[88vh] scroll-mt-48 overflow-hidden bg-[#e1e1dc] py-14">
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(225,225,220,0.9),rgba(225,225,220,0.97))]"></div>

        <div class="section-wrap relative z-10">
          <div class="mb-8 section-reveal">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#7a6e60]">{copy.practicesKicker}</p>
            <h2 class="mt-3 text-5xl leading-[0.95] text-[#2b3447] md:text-6xl">{copy.practicesHeading}</h2>
            <p class="mt-5 max-w-3xl text-lg leading-8 text-[#4c5568]">{copy.practicesLead}</p>
          </div>

          <div class="practice-list section-reveal">
            <div class="practice-list-head">
              <p class="practice-list-head-title">
                {copy.practicesHeadLine1}
                <br />
                {copy.practicesHeadLine2}
              </p>
              <a href="#contact" class="practice-list-head-link">
                {copy.practicesHeadCta}
              </a>
            </div>

            {PRACTICE_ORDER.map((slug, index) => {
              const card = t.practices[slug];
              const imagePosition = ['center 34%', 'center 52%', 'center 68%'][index] ?? 'center 50%';
              return (
                <article class="practice-list-item">
                  <img
                    src={practiceImageBySlug[slug] ?? '/assets/section-practices.jpg'}
                    alt={card.title}
                    class="practice-list-thumb"
                    style={`object-position:${imagePosition};`}
                    loading="lazy"
                  />
                  <p class="practice-list-number">{String(index + 1).padStart(2, '0')}</p>
                  <div class="practice-list-content">
                    <h3 class="practice-list-title">{card.title}</h3>
                    <p class="practice-list-summary">{card.summary}</p>
                    <a class="practice-list-cta" href={buildLangPath(lang, `/practice-areas/${slug}`)}>
                      {card.cta} →
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="contact" data-nav-section class="section-divider relative min-h-[78vh] scroll-mt-48 overflow-hidden bg-[#f0e7d9] py-16 text-[#12161f]">
        <div class="section-wrap relative z-10">
          <div class="section-reveal">
            <h3 class="text-center text-4xl leading-none text-[#12161f] md:text-5xl">{copy.contactTitle}</h3>
            <p class="mx-auto mt-4 max-w-2xl text-center text-base text-[#3c4452]">
              {copy.contactSubtitle}
            </p>

            <div class="mx-auto mt-14 grid max-w-5xl gap-12 md:grid-cols-[1.2fr_1fr]">
              <div>
                <h4 class="text-3xl text-[#12161f] md:text-4xl">{copy.addressTitle}</h4>
                <p class="mt-5 text-base leading-[1.7] text-[#1f2633] md:text-[1.02rem]">{OFFICE_INFO.istanbul.address}</p>
                <a href={istanbulMapOpenUrl} target="_blank" rel="noreferrer" class="mt-3 inline-block text-sm font-semibold text-[#2f3f62] underline underline-offset-4 hover:text-[#1e2a43]">
                  {copy.openMap} →
                </a>
                <div class="mt-5 overflow-hidden rounded-2xl border border-[#c8c8c8] bg-white shadow-[0_8px_20px_rgba(0,0,0,0.05)]">
                  <iframe
                    src={istanbulMapEmbedUrl}
                    title="Mayısgülü Sokak No:8 Daire:8 Kadıköy/İstanbul harita"
                    class="h-[210px] w-full"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                  ></iframe>
                </div>
              </div>

              <div>
                <h4 class="text-3xl text-[#12161f] md:text-4xl">{copy.otherContactTitle}</h4>
                <div class="mt-5 space-y-3 text-base leading-[1.7] text-[#1f2633] md:text-[1.02rem]">
                  <a href={`tel:${OFFICE_INFO.phone}`} class="block border-b border-[#bfc4cd] pb-2 hover:text-[#000000]">{copy.phoneLabel}: {OFFICE_INFO.phone}</a>
                  <a href={`mailto:${OFFICE_INFO.email}`} class="block border-b border-[#bfc4cd] pb-2 hover:text-[#000000]">{copy.emailLabel}: {OFFICE_INFO.email}</a>
                  <a
                    href={OFFICE_INFO.linkedin}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center gap-2 rounded-full border border-[#222833] px-4 py-2 text-sm font-semibold hover:bg-[#222833] hover:text-white"
                  >
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-current text-xs font-bold">in</span>
                    <span>LinkedIn</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="newsletter" class="section-divider newsletter-sky relative overflow-hidden bg-[#5f6b7d] py-7 text-[#f4f7fd]">
        <div class="section-wrap">
          <p class="section-reveal text-xs font-semibold uppercase tracking-[0.2em] text-[#ead9b7]">{copy.newsletterLabel}</p>

          <div class="mt-3 grid gap-6 md:grid-cols-[1.1fr_1.9fr] md:items-center">
          <div class="section-reveal">
            <h3 class="max-w-[46ch] text-base leading-[1.3] text-[#f4f7fd] md:text-lg">
              {copy.newsletterTextLine1}
              <br class="hidden md:block" />
              {copy.newsletterTextLine2}
            </h3>
          </div>

          <div class="section-reveal">
            <form id="newsletter-form" class="newsletter-inline-form md:ml-auto md:w-full md:max-w-[860px]" method="post" action="/api/newsletter/subscribe">
              <input type="hidden" name="source" value="footer-newsletter" />
              <div class="grid gap-2 md:grid-cols-[1fr_auto] md:items-center">
                <div class="space-y-2">
                  <div class="grid gap-2 md:grid-cols-2">
                    <label class="newsletter-field">
                      <span>{copy.firstName}</span>
                      <input name="firstName" />
                    </label>
                    <label class="newsletter-field">
                      <span>{copy.lastName}</span>
                      <input name="lastName" />
                    </label>
                  </div>
                  <label class="newsletter-field block">
                    <span>{copy.emailLabel} *</span>
                    <input required type="email" name="email" />
                  </label>
                </div>
                <div class="newsletter-submit-wrap md:pl-3">
                  <button type="submit" class="newsletter-outline-btn">{copy.subscribe}</button>
                </div>
              </div>
            </form>
            <p id="newsletter-feedback" class="mt-2 text-xs text-[#f4f7fd] md:text-sm"></p>
          </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    const wireForm = (formId, feedbackId) => {
      const form = document.getElementById(formId);
      const feedback = document.getElementById(feedbackId);
      if (!form || !feedback) return;

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        feedback.textContent = '';
        const formData = new FormData(form);

        const response = await fetch(form.getAttribute('action') || '', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();
        if (result.ok) {
          form.reset();
          feedback.textContent = result.message;
          feedback.className = 'text-sm text-emerald-700';
        } else {
          feedback.textContent = result.message;
          feedback.className = 'text-sm text-rose-700';
        }
      });
    };

    wireForm('newsletter-form', 'newsletter-feedback');

    const reveals = document.querySelectorAll('.section-reveal');
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.14 }
    );
    reveals.forEach((el) => revealObserver.observe(el));

    const heroStage = document.getElementById('hero-stage');
    const heroCopyBlock = document.getElementById('hero-copy');
    const heroVideo = document.getElementById('hero-video');
    if (heroVideo && heroVideo instanceof HTMLVideoElement) {
      let forcedOnce = false;
      const seekToEightSeconds = () => {
        try {
          heroVideo.currentTime = 8;
        } catch {}
      };
      if (heroVideo.readyState >= 1) {
        seekToEightSeconds();
      } else {
        heroVideo.addEventListener('loadedmetadata', seekToEightSeconds, { once: true });
      }
      // Start with a short delay for calmer entrance.
      window.setTimeout(() => {
        heroVideo.play().catch(() => {});
      }, 2000);
      heroVideo.addEventListener('play', () => {
        if (forcedOnce) return;
        if (heroVideo.currentTime < 7.8) {
          seekToEightSeconds();
        }
        forcedOnce = true;
      });
    }
    let heroCollapsed = false;
    let snapInProgress = false;
    let snapTimer = 0;
    let lastScrollY = window.scrollY;
    let lastScrollDir = 'down';
    const applyHeroCollapsed = (next) => {
      heroCollapsed = next;
      if (heroStage) heroStage.classList.toggle('hero-stage-collapsed', heroCollapsed);
      if (heroCopyBlock) heroCopyBlock.classList.toggle('hero-copy-hidden', heroCollapsed);
      // Reduce runtime load after leaving hero viewport.
      if (heroVideo && heroVideo instanceof HTMLVideoElement) {
        if (heroCollapsed) {
          heroVideo.pause();
        } else {
          heroVideo.play().catch(() => {});
        }
      }
    };
    const observedSections = [...document.querySelectorAll('[data-nav-section]')];
    if (observedSections.length) {
      const aboutSection = document.getElementById('about');
      const getAboutTop = () => {
        if (!aboutSection) return Infinity;
        const headerEl = document.getElementById('site-header');
        const headerOffset = headerEl?.offsetHeight ?? 96;
        return aboutSection.getBoundingClientRect().top + window.scrollY - (headerOffset + 12);
      };

      const snapToNearestSection = () => {
        if (!aboutSection || snapInProgress) return;
        if (window.location.hash && window.location.hash.length > 1) return;
        const y = window.scrollY;
        const aboutTop = getAboutTop();
        if (!Number.isFinite(aboutTop) || aboutTop <= 0) return;

        // Only resolve when user is in the in-between area.
        if (y <= 14 || y >= aboutTop - 8) return;

        // Follow user's last scroll direction to avoid bounce-back feeling.
        const target = lastScrollDir === 'down' ? Math.max(0, aboutTop) : 0;
        snapInProgress = true;
        if (target > 0) {
          applyHeroCollapsed(true);
        }
        window.scrollTo({ top: target, behavior: 'smooth' });
        window.setTimeout(() => {
          snapInProgress = false;
        }, 420);
      };

      const queueSnapResolve = () => {
        window.clearTimeout(snapTimer);
        snapTimer = window.setTimeout(snapToNearestSection, 120);
      };

      const updateStageOnScroll = () => {
        const y = window.scrollY;
        const hasSectionHash = !!(window.location.hash && window.location.hash.length > 1);
        if (Math.abs(y - lastScrollY) > 1) {
          lastScrollDir = y > lastScrollY ? 'down' : 'up';
          lastScrollY = y;
        }

        // If user is navigating sections, keep hero collapsed to prevent jump/flicker.
        if (hasSectionHash && y > 10) {
          applyHeroCollapsed(true);
        } else {
          // Collapse quickly when user starts leaving hero; expand only at near-top.
          if (!heroCollapsed && y > 90) {
            applyHeroCollapsed(true);
          } else if (heroCollapsed && y < 20) {
            applyHeroCollapsed(false);
          }
        }

        // Resolve "in-between" hero state only after scrolling pauses.
        if (!hasSectionHash) {
          queueSnapResolve();
        }
      };

      updateStageOnScroll();
      window.addEventListener('scroll', updateStageOnScroll, { passive: true });
    }

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (event) => {
        const href = anchor.getAttribute('href') || '';
        if (!href.startsWith('#')) return;
        const target = document.querySelector(href);
        if (!target) return;
        event.preventDefault();
        if (href !== '#') {
          applyHeroCollapsed(true);
          window.history.replaceState({}, '', href);
        }
        const headerEl = document.getElementById('site-header');
        const headerOffset = headerEl?.offsetHeight ?? 96;
        const top = target.getBoundingClientRect().top + window.scrollY - (headerOffset + 12);
        window.requestAnimationFrame(() => {
          window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
        });
      });
    });

  </script>
</BaseLayout>
