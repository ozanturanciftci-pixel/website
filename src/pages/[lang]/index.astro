---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  type Lang,
  PRACTICE_ORDER,
  SITE_CONTENT,
  OFFICE_INFO,
  isLang
} from '@/content/site';

const langParam = Astro.params.lang;
if (!langParam || !isLang(langParam)) {
  return Astro.redirect('/tr');
}

const lang = langParam as Lang;
const t = SITE_CONTENT[lang];
const heroCopy: Record<Lang, { kicker: string; title: string; subtitle: string }> = {
  tr: {
    kicker: 'Turançiftçi Hukuk Bürosu',
    title: 'Hukukta İsabet\nİletişimde Güven',
    subtitle: 'Vergi ve şirketler hukuku başta olmak üzere, uluslararası standartlarda, güvenilir ve sonuç odaklı hukuki danışmanlık ve avukatlık hizmetleri sunuyoruz'
  },
  en: {
    kicker: 'Turançiftçi Law Firm',
    title: 'Precision in Law\nReliability in Advisory',
    subtitle: 'We provide reliable and result-oriented legal advisory and advocacy services at international standards, with a focus on tax and corporate law'
  },
  es: {
    kicker: 'Bufete Turançiftçi',
    title: 'Precisión en Derecho\nConfiabilidad en Asesoría',
    subtitle: 'Ofrecemos servicios de asesoría y abogacía jurídica, confiables y orientados a resultados, con estándares internacionales y enfoque en derecho fiscal y societario'
  }
};

const uiCopy: Record<
  Lang,
  {
    heroReach: string;
    aboutKicker: string;
    practicesKicker: string;
    practicesHeading: string;
    practicesLead: string;
    practicesHeadLine1: string;
    practicesHeadLine2: string;
    practicesHeadCta: string;
    contactTitle: string;
    contactSubtitle: string;
    addressTitle: string;
    otherContactTitle: string;
    openMap: string;
    newsletterLabel: string;
    newsletterTextLine1: string;
    newsletterTextLine2: string;
    firstName: string;
    lastName: string;
    emailLabel: string;
    phoneLabel: string;
    subscribe: string;
  }
> = {
  tr: {
    heroReach: 'Hemen Ulaşın',
    aboutKicker: 'Hakkında',
    practicesKicker: 'Uzmanlık Alanlarımız',
    practicesHeading: 'Uzmanlık ve Çözümler',
    practicesLead: 'Vergi ve şirketler hukuku başta olmak üzere uzmanlaştığımız alanlarda, hukuki bilgiyi iş dünyasının ihtiyaçlarıyla buluşturuyoruz. Her aşamada netlik, hız ve güven esaslı bir yaklaşımla, sonuç odaklı hukuki çözümler sunuyoruz.',
    practicesHeadLine1: '',
    practicesHeadLine2: '',
    practicesHeadCta: 'Hemen Ulaşın',
    contactTitle: 'Bize Ulaşın',
    contactSubtitle: 'Hukuki ihtiyacınızı kısaca paylaşın; en uygun yol haritası için sizinle iletişime geçelim.',
    addressTitle: 'Adres',
    otherContactTitle: 'Diğer İletişim Bilgileri',
    openMap: 'Haritada Aç',
    newsletterLabel: 'Bülten',
    newsletterTextLine1: 'Önemli gelişmelerden haberdar olmak için',
    newsletterTextLine2: 'bültenimize abone olabilirsiniz.',
    firstName: 'İsim',
    lastName: 'Soyisim',
    emailLabel: 'E-posta',
    phoneLabel: 'Telefon',
    subscribe: 'Abone Ol'
  },
  en: {
    heroReach: 'Reach Us',
    aboutKicker: 'About Us',
    practicesKicker: 'Practice Areas',
    practicesHeading: 'Expertise and Solutions',
    practicesLead: 'Focused representation and strategic legal counsel in tax law, corporate law and immigration law.',
    practicesHeadLine1: 'Discover the strategic advantages',
    practicesHeadLine2: 'offered by our practice areas.',
    practicesHeadCta: 'Reach Us',
    contactTitle: 'Reach Us',
    contactSubtitle: 'Share your legal need briefly; we will contact you with the most suitable roadmap.',
    addressTitle: 'Address',
    otherContactTitle: 'Other Contact Details',
    openMap: 'Open in Maps',
    newsletterLabel: 'Newsletter',
    newsletterTextLine1: 'Subscribe to stay informed about',
    newsletterTextLine2: 'important legal developments.',
    firstName: 'First Name',
    lastName: 'Last Name',
    emailLabel: 'Email',
    phoneLabel: 'Phone',
    subscribe: 'Subscribe'
  },
  es: {
    heroReach: 'Contáctenos',
    aboutKicker: 'Sobre Nosotros',
    practicesKicker: 'Áreas de Práctica',
    practicesHeading: 'Experiencia y Soluciones',
    practicesLead: 'Representación enfocada y asesoría jurídica estratégica en derecho fiscal, societario y de extranjería.',
    practicesHeadLine1: 'Descubra las ventajas estratégicas',
    practicesHeadLine2: 'de nuestras áreas de práctica.',
    practicesHeadCta: 'Contáctenos',
    contactTitle: 'Contáctenos',
    contactSubtitle: 'Comparta brevemente su necesidad legal; le contactaremos con la hoja de ruta más adecuada.',
    addressTitle: 'Dirección',
    otherContactTitle: 'Otros Datos de Contacto',
    openMap: 'Abrir en Mapas',
    newsletterLabel: 'Boletín',
    newsletterTextLine1: 'Suscríbase para mantenerse al tanto de',
    newsletterTextLine2: 'desarrollos legales importantes.',
    firstName: 'Nombre',
    lastName: 'Apellido',
    emailLabel: 'Correo',
    phoneLabel: 'Teléfono',
    subscribe: 'Suscribirse'
  }
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Turançiftçi Law Firm',
  areaServed: ['Istanbul', 'Madrid'],
  telephone: OFFICE_INFO.phone,
  email: OFFICE_INFO.email,
  address: [OFFICE_INFO.istanbul.address, OFFICE_INFO.madrid.address],
  serviceType: [
    t.practices['tax-law'].title,
    t.practices['corporate-law'].title,
    t.practices['immigration-law'].title
  ]
};

const practiceImageBySlug: Record<string, string> = {
  'tax-law': '/assets/practice-tax.jpg',
  'corporate-law': '/assets/practice-corporate.jpg',
  'immigration-law': '/assets/practice-immigration.jpg'
};
const aboutIntroByLang: Record<Lang, string> = {
  tr: 'Vergi ve şirketler hukuku başta olmak üzere, stratejik ve sonuç odaklı hukuki danışmanlık sunmak amacıyla kurulmuştur. Büro, ticari gerçeklikleri gözeten bakış açısını hukuki uzmanlıkla birleştirerek, riskleri öngören ve müvekkillerine küresel ölçekte sürdürülebilir, uygulanabilir ve değer yaratan çözümler sunar.',
  en: 'Founded to provide strategic and result-oriented legal counsel at international standards, with a primary focus on tax and corporate law. The firm combines legal expertise with commercial realities to anticipate risks and deliver sustainable, practical and value-creating solutions to clients worldwide.',
  es: 'Fundado para ofrecer asesoría jurídica estratégica y orientada a resultados, con estándares internacionales y enfoque principal en derecho fiscal y societario. El despacho combina la experiencia jurídica con la realidad comercial para anticipar riesgos y ofrecer soluciones sostenibles, aplicables y generadoras de valor para clientes a nivel global.'
};
const founderContentByLang: Record<Lang, { title: string; paragraphs: string[] }> = {
  tr: {
    title: 'Av. Ozan Turançiftçi – Ortak',
    paragraphs: [
      'Av. Ozan Turançiftçi, vergi ve hukuk alanında çok uluslu şirketlere yönelik danışmanlık deneyimine sahip bir avukattır. İstanbul Barosu’na kayıtlı olup, uluslararası vergi ve şirketler hukuku alanlarında uzmanlaşmıştır. Kariyeri boyunca PwC ve EY gibi dünyanın önde gelen danışmanlık firmalarında görev almış; doğrudan ve dolaylı vergiler, transfer fiyatlandırması, KDV ve gümrük uygulamaları gibi kompleks konularda çok uluslu müvekkillere danışmanlık sağlamıştır.',
      'Vergi risklerinin analiz edilmesi, stratejik planlama fırsatlarının belirlenmesi ve uyuşmazlık süreçlerinin yönetilmesi konularında aktif rol almış; müvekkillerini idari ve yargısal süreçlerde temsil etmiştir. Madrid’de bulunan Universidad Carlos III de Madrid bünyesinde MBA eğitimini tamamlayan Turançiftçi, iş dünyası ile hukuku bir araya getiren bütüncül bir bakış açısına sahiptir. İngilizce, Türkçe, İspanyolca ve Fransızca dillerinde hizmet verebilmekte olup, kurucusu olduğu büroda teknik doğruluğu yüksek, ticari açıdan uygulanabilir ve müvekkil odaklı çözümler sunmayı temel ilke edinmiştir.'
    ]
  },
  en: {
    title: 'Atty. Ozan Turançiftçi – Founder',
    paragraphs: [
      'Atty. Ozan Turançiftçi is a lawyer with advisory experience for multinational companies in tax and business law. He is registered with the Istanbul Bar and focuses on international tax and corporate matters. During his career at leading advisory firms such as PwC and EY, he advised multinational clients on complex topics including direct and indirect taxes, transfer pricing, VAT and customs practices.',
      'He has actively supported tax risk analysis, strategic planning opportunities and dispute management, and represented clients in administrative and judicial proceedings. After completing his MBA at Universidad Carlos III de Madrid, he developed a holistic perspective that combines legal expertise with business realities. He provides services in English, Turkish, Spanish and French, and leads the firm with a focus on technically sound, commercially practical and client-oriented legal solutions.'
    ]
  },
  es: {
    title: 'Abg. Ozan Turançiftçi – Fundador',
    paragraphs: [
      'El Abg. Ozan Turançiftçi cuenta con experiencia asesorando a empresas multinacionales en materia fiscal y jurídica. Está colegiado en el Colegio de Abogados de Estambul y se especializa en derecho fiscal y societario internacional. A lo largo de su carrera en firmas líderes como PwC y EY, asesoró a clientes multinacionales en asuntos complejos como impuestos directos e indirectos, precios de transferencia, IVA y prácticas aduaneras.',
      'Ha participado activamente en análisis de riesgos fiscales, planificación estratégica y gestión de controversias, representando a clientes en procedimientos administrativos y judiciales. Tras completar su MBA en la Universidad Carlos III de Madrid, consolidó una visión integral que une el derecho con la realidad empresarial. Presta servicios en inglés, turco, español y francés, y dirige el despacho con un enfoque técnico, aplicable y centrado en el cliente.'
    ]
  }
};
const aboutLogoByLang: Record<Lang, string> = {
  tr: '/assets/about-logo-tr.svg',
  en: '/assets/about-logo-en.svg',
  es: '/assets/about-logo-es.svg'
};

const copy = uiCopy[lang];
---

<BaseLayout lang={lang} path="/" structuredData={structuredData}>
  <div class="relative bg-[#efe4d3]">
    <div id="hero-ribbon" class="hero-ribbon" aria-hidden="true">
      <video
        id="hero-ribbon-video"
        class="hero-ribbon-video"
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src="/assets/hero-video.mp4#t=8" type="video/mp4" />
      </video>
      <div class="hero-ribbon-overlay"></div>
    </div>

    <section id="hero-stage" class="snap-section relative z-30 h-[100svh] min-h-[100svh] md:h-[80svh] md:min-h-[560px]">
      <div class="relative h-full overflow-hidden">
        <video
          id="hero-video"
          class="stage-image active pointer-events-none absolute inset-0 h-full w-full object-cover object-[center_48%]"
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        >
          <source src="/assets/hero-video.mp4#t=8" type="video/mp4" />
        </video>

        <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.52),rgba(0,0,0,0.28),rgba(0,0,0,0.48))]"></div>
        <div id="hero-copy" class="hero-copy-shell absolute inset-x-0 z-10 text-[#f8f1df]">
          <div class="mx-auto w-full max-w-4xl translate-y-4 text-center md:translate-y-8">
            <div class="translate-y-4 md:translate-y-6">
              <h1 class="whitespace-pre-line text-[2rem] leading-[1.12] text-[#fff8ea] md:text-[3.2rem]">{heroCopy[lang].title}</h1>
              <div class="mt-3 h-5 md:h-7" aria-hidden="true"></div>
            </div>
            <a href={`mailto:${OFFICE_INFO.email}`} class="hero-contact-pill mt-9 inline-flex md:mt-10" aria-label={copy.heroReach}>
              <span class="hero-contact-pill-label">{copy.heroReach}</span>
              <span class="hero-contact-pill-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 6h16v12H4z"></path>
                  <path d="m4 7 8 6 8-6"></path>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="relative z-10 border-t border-[#d8d2c8] pt-0">
      <section id="about" data-nav-section class="snap-section relative min-h-[100svh] scroll-mt-48 overflow-hidden bg-[#f0e7d9] pb-10 pt-10 md:pb-14 md:pt-6">
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(240,231,217,0.90),rgba(240,231,217,0.97))]"></div>

        <div class="section-wrap relative z-10 md:px-9 xl:px-14">
          <div class="section-reveal">
            <div class="mt-2 grid items-center gap-5 md:mt-1 md:grid-cols-[minmax(320px,auto)_minmax(0,1fr)] md:gap-9">
              <img
                src={aboutLogoByLang[lang]}
                alt="Turançiftçi"
                class="mx-auto h-[3.75rem] w-auto md:mx-0 md:h-[6.5rem]"
                transition:name="hero"
                loading="lazy"
              />
              <p class="text-justify text-lg italic leading-9 text-[#4c5568]">
                {aboutIntroByLang[lang]}
              </p>
            </div>

            <div class="mt-10 border-t border-[#d4ccbe] pt-8 md:px-12 lg:px-20">
              <div class="grid items-center gap-6 md:grid-cols-[minmax(0,0.84fr)_270px] md:gap-12">
                <div class="max-w-[64ch] space-y-6 text-[#4c5568]">
                  <h3 class="text-center text-3xl leading-tight tracking-[0.01em] text-[#2b3447] md:text-left md:text-4xl">{founderContentByLang[lang].title}</h3>
                  <img
                    src="/assets/ozan-profile.jpeg"
                    alt="Av. Ozan Turançiftçi"
                    class="mx-auto h-[170px] w-[170px] rounded-full border border-[#c9c1b3] object-cover shadow-[0_10px_24px_rgba(35,43,58,0.12)] md:hidden"
                    loading="lazy"
                  />
                  {founderContentByLang[lang].paragraphs.map((paragraph) => (
                    <p class="text-justify text-[1.045rem] leading-[2.05] tracking-[0.01em] text-[#46536b]">{paragraph}</p>
                  ))}
                </div>
                <img
                  src="/assets/ozan-profile.jpeg"
                  alt="Av. Ozan Turançiftçi"
                  class="hidden h-[195px] w-[195px] rounded-full border border-[#c9c1b3] object-cover shadow-[0_10px_24px_rgba(35,43,58,0.12)] md:block md:h-[240px] md:w-[240px] md:justify-self-center"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="practices" data-nav-section class="snap-section section-divider relative min-h-[100svh] scroll-mt-48 overflow-hidden bg-[#e1e1dc] py-14">
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(225,225,220,0.9),rgba(225,225,220,0.97))]"></div>

        <div class="section-wrap relative z-10 md:px-12 lg:px-20">
          <div class="mb-8 section-reveal">
            <div class="md:grid md:grid-cols-[auto_minmax(0,1fr)] md:items-start md:gap-10">
              <h2 class="text-center text-5xl leading-[0.95] text-[#2b3447] md:pt-1 md:text-left md:text-6xl">{copy.practicesKicker}</h2>
              <p class="mt-5 text-justify text-lg italic leading-8 text-[#4c5568] md:mt-0">{copy.practicesLead}</p>
            </div>
          </div>

          <div class="practice-list section-reveal">
            {PRACTICE_ORDER.map((slug, index) => {
              const card = t.practices[slug];
              const imagePosition = ['center 34%', 'center 52%', 'center 68%'][index] ?? 'center 50%';
              const tone = [
                'rgba(244,239,229,0.96)',
                'rgba(238,241,236,0.96)',
                'rgba(236,240,244,0.96)'
              ][index] ?? 'rgba(244,239,229,0.96)';
              return (
                <article class="practice-list-item" style={`--card-bg:${tone};`}>
                  <img
                    src={practiceImageBySlug[slug] ?? '/assets/section-practices.jpg'}
                    alt={card.title}
                    class="practice-list-thumb"
                    style={`object-position:${imagePosition};`}
                    loading="lazy"
                  />
                  <div class="practice-list-content">
                    <h3 class="practice-list-title">{card.title}</h3>
                    <p class="practice-list-summary">{card.summary}</p>
                    <ul class="practice-list-bullets">
                      {card.bullets.map((bullet) => <li>{bullet}</li>)}
                    </ul>
                    <a class="practice-list-cta" href="#contact">
                      {card.cta}
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="contact" data-nav-section class="snap-section section-divider relative min-h-[64svh] scroll-mt-48 overflow-hidden bg-[#f0e7d9] pb-8 pt-12 text-[#12161f]">
        <div class="section-wrap relative z-10 md:px-12 lg:px-20">
          <div class="section-reveal">
            <h3 class="text-5xl leading-[0.95] text-[#2b3447] md:text-6xl">{copy.contactTitle}</h3>
            <p class="mt-3 text-base leading-8 text-[#4c5568] pt-serif-copy md:text-lg md:whitespace-nowrap">
              {copy.contactSubtitle}
            </p>

            <div class="mt-6">
              <div class="mb-7 flex items-center justify-start gap-4">
                <a
                  href={`mailto:${OFFICE_INFO.email}`}
                  class="inline-flex items-center gap-2 rounded-full border border-[#2b3447] px-4 py-2 text-[#2b3447] transition hover:bg-[#2b3447] hover:text-white"
                  aria-label="E-posta gönder"
                >
                  <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6h16v12H4z"></path>
                    <path d="m4 7 8 6 8-6"></path>
                  </svg>
                  <span class="text-sm font-normal">{OFFICE_INFO.email}</span>
                </a>
                <a
                  href={OFFICE_INFO.linkedin}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-[#2b3447] px-4 py-2 text-[#2b3447] transition hover:bg-[#2b3447] hover:text-white"
                  aria-label="LinkedIn"
                >
                  <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-current text-xs font-bold">in</span>
                  <span class="text-sm font-normal">LinkedIn</span>
                </a>
              </div>

              <div class="grid gap-7 md:grid-cols-2 md:gap-8">
                <div class="grid grid-cols-[120px_minmax(0,1fr)] items-start gap-4 md:grid-cols-[200px_minmax(0,1fr)]">
                  <img
                    src="/assets/contact-istanbul.jpg"
                    alt="Istanbul office"
                    class="h-44 w-full rounded-2xl border border-[#c8c8c8] object-cover object-[center_22%] shadow-[0_8px_20px_rgba(0,0,0,0.05)] md:h-56"
                    loading="lazy"
                  />
                  <div>
                    <p class="text-xl font-semibold text-[#222b3d]">İstanbul</p>
                    <p class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-[#55607a]">{copy.addressTitle}</p>
                    <p class="mt-2 text-base leading-[1.7] text-[#1f2633] md:text-[1.02rem]">Kadıköy, İstanbul</p>
                  </div>
                </div>

                <div class="grid grid-cols-[120px_minmax(0,1fr)] items-start gap-4 md:grid-cols-[200px_minmax(0,1fr)]">
                  <img
                    src="/assets/contact-madrid.jpg"
                    alt="Madrid office"
                    class="h-44 w-full rounded-2xl border border-[#c8c8c8] object-cover object-top shadow-[0_8px_20px_rgba(0,0,0,0.05)] md:h-56"
                    loading="lazy"
                  />
                  <div>
                    <p class="text-xl font-semibold text-[#222b3d]">Madrid</p>
                    <p class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-[#55607a]">{copy.addressTitle}</p>
                    <p class="mt-2 text-base leading-[1.7] text-[#1f2633] md:text-[1.02rem]">Embajadores, Madrid</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="newsletter" class="section-divider newsletter-sky relative overflow-hidden bg-[#5f6b7d] py-7 text-[#f4f7fd]">
        <div class="section-wrap">
          <div class="newsletter-topbar section-reveal">
            <div class="newsletter-topbar-logo-wrap">
              <img src="/assets/t-logo.svg" alt="T logo" class="newsletter-topbar-logo newsletter-topbar-logo-svg" loading="lazy" />
            </div>
            <span class="newsletter-topbar-divider newsletter-topbar-divider-primary" aria-hidden="true"></span>
            <div class="newsletter-topbar-center">
              <div class="newsletter-topbar-copy">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#ead9b7]">{copy.newsletterLabel}</p>
                <h3 class="mt-2 text-base leading-[1.3] text-[#f4f7fd] md:text-lg">
                  {copy.newsletterTextLine1}
                  <br class="hidden md:block" />
                  {copy.newsletterTextLine2}
                </h3>
              </div>
              <form id="newsletter-topbar-form" class="newsletter-topbar-form hidden md:flex" method="post" action="/api/newsletter/subscribe">
                <input type="hidden" name="source" value="footer-newsletter-topbar" />
                <input name="firstName" placeholder={copy.firstName} />
                <input name="lastName" placeholder={copy.lastName} />
                <input required type="email" name="email" placeholder={`${copy.emailLabel} *`} />
                <button type="submit">{copy.subscribe}</button>
              </form>
            </div>
            <span class="newsletter-topbar-divider newsletter-topbar-divider-secondary hidden md:block" aria-hidden="true"></span>
            <div class="newsletter-topbar-links">
              <a href={`mailto:${OFFICE_INFO.email}`} class="newsletter-topbar-link">{OFFICE_INFO.email}</a>
              <a href={OFFICE_INFO.linkedin} target="_blank" rel="noreferrer" class="newsletter-topbar-link newsletter-topbar-linkedin" aria-label="LinkedIn">
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-current text-xs font-bold">in</span>
                <span>LinkedIn</span>
              </a>
            </div>
          </div>

          <div class="mt-4 section-reveal md:hidden">
            <form id="newsletter-form" class="newsletter-inline-form newsletter-compact-form md:w-full md:max-w-[680px]" method="post" action="/api/newsletter/subscribe">
              <input type="hidden" name="source" value="footer-newsletter" />
              <div class="grid gap-2 md:grid-cols-[1fr_auto] md:items-center">
                <div class="space-y-2">
                  <div class="grid gap-2 md:grid-cols-2">
                    <label class="newsletter-field">
                      <span>{copy.firstName}</span>
                      <input name="firstName" />
                    </label>
                    <label class="newsletter-field">
                      <span>{copy.lastName}</span>
                      <input name="lastName" />
                    </label>
                  </div>
                  <label class="newsletter-field block">
                    <span>{copy.emailLabel} *</span>
                    <input required type="email" name="email" />
                  </label>
                </div>
                <div class="newsletter-submit-wrap md:pl-3">
                  <button type="submit" class="newsletter-outline-btn">{copy.subscribe}</button>
                </div>
              </div>
            </form>
            <p id="newsletter-feedback" class="mt-2 text-xs text-[#f4f7fd] md:text-sm"></p>
          </div>
          <p id="newsletter-topbar-feedback" class="mt-2 hidden text-xs text-[#f4f7fd] md:block md:text-sm"></p>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    const wireForm = (formId, feedbackId) => {
      const form = document.getElementById(formId);
      const feedback = document.getElementById(feedbackId);
      if (!form || !feedback) return;

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        feedback.textContent = '';
        const formData = new FormData(form);

        const response = await fetch(form.getAttribute('action') || '', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();
        if (result.ok) {
          form.reset();
          feedback.textContent = result.message;
          feedback.className = 'text-sm text-emerald-700';
        } else {
          feedback.textContent = result.message;
          feedback.className = 'text-sm text-rose-700';
        }
      });
    };

    wireForm('newsletter-form', 'newsletter-feedback');
    wireForm('newsletter-topbar-form', 'newsletter-topbar-feedback');

    const reveals = document.querySelectorAll('.section-reveal');
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.14 }
    );
    reveals.forEach((el) => revealObserver.observe(el));

    const heroCopyBlock = document.getElementById('hero-copy');
    const heroRibbon = document.getElementById('hero-ribbon');
    const heroStage = document.getElementById('hero-stage');
    const headerEl = document.getElementById('site-header');
    const headerNavShell = document.getElementById('header-nav-shell');
    const heroVideo = document.getElementById('hero-video');
    const heroRibbonVideo = document.getElementById('hero-ribbon-video');
    const RIBBON_START_TIME = 8;
    let ribbonAutoStarted = false;

    const startRibbonPlayback = () => {
      if (!(heroRibbonVideo && heroRibbonVideo instanceof HTMLVideoElement)) return;
      if (ribbonAutoStarted) return;
      ribbonAutoStarted = true;
      try {
        heroRibbonVideo.currentTime = RIBBON_START_TIME;
      } catch {}
      heroRibbonVideo.play().catch(() => {});
    };

    const getPanelBottom = () => {
      if (headerNavShell) {
        const navStyle = window.getComputedStyle(headerNavShell);
        if (navStyle.display !== 'none') {
          return headerNavShell.getBoundingClientRect().bottom;
        }
      }
      return headerEl?.getBoundingClientRect().bottom ?? 96;
    };

    const shouldShowRibbon = () => {
      if (!heroStage) return window.scrollY > 120;
      const heroBottom = heroStage.getBoundingClientRect().bottom;
      return heroBottom <= getPanelBottom() + 1;
    };

    if (heroVideo && heroVideo instanceof HTMLVideoElement) {
      let forcedOnce = false;
      const seekToEightSeconds = () => {
        try {
          heroVideo.currentTime = RIBBON_START_TIME;
        } catch {}
      };
      if (heroVideo.readyState >= 1) {
        seekToEightSeconds();
      } else {
        heroVideo.addEventListener('loadedmetadata', seekToEightSeconds, { once: true });
      }
      // Start with a short delay for calmer entrance.
      window.setTimeout(() => {
        heroVideo.play().catch(() => {});
      }, 2000);
      heroVideo.addEventListener('play', () => {
        if (forcedOnce) return;
        if (heroVideo.currentTime < 7.8) {
          seekToEightSeconds();
        }
        forcedOnce = true;
      });
    }
    if (heroRibbonVideo && heroRibbonVideo instanceof HTMLVideoElement) {
      const seekRibbon = () => {
        try {
          heroRibbonVideo.currentTime = RIBBON_START_TIME;
        } catch {}
      };
      if (heroRibbonVideo.readyState >= 1) {
        seekRibbon();
      } else {
        heroRibbonVideo.addEventListener('loadedmetadata', seekRibbon, { once: true });
      }
      heroRibbonVideo.pause();
    }
    if (heroCopyBlock) {
      const syncHeroCopyFade = () => {
        const hideHeroCopy = window.scrollY > 24;
        const showRibbon = shouldShowRibbon();
        heroCopyBlock.classList.toggle('hero-copy-hidden', hideHeroCopy);

        if (heroRibbon) {
          heroRibbon.classList.toggle('hero-ribbon-visible', showRibbon);
        }
        if (showRibbon) startRibbonPlayback();
      };
      syncHeroCopyFade();
      window.addEventListener('scroll', syncHeroCopyFade, { passive: true });
      window.addEventListener('resize', syncHeroCopyFade);
    }

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (event) => {
        const href = anchor.getAttribute('href') || '';
        if (!href.startsWith('#')) return;
        const target = document.querySelector(href);
        if (!target) return;
        event.preventDefault();
        if (href !== '#') window.history.replaceState({}, '', href);
        const headerEl = document.getElementById('site-header');
        const headerOffset = headerEl?.offsetHeight ?? 96;
        const extraLift = href === '#about' ? -12 : 0;
        const top = target.getBoundingClientRect().top + window.scrollY - Math.max(0, headerOffset - extraLift);
        window.requestAnimationFrame(() => {
          window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
        });
      });
    });

  </script>
</BaseLayout>
