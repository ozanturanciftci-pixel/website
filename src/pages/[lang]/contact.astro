---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Lang, OFFICE_INFO, SITE_CONTENT, isLang } from '@/content/site';

const langParam = Astro.params.lang;
if (!langParam || !isLang(langParam)) {
  return Astro.redirect('/tr');
}

const lang = langParam as Lang;
const t = SITE_CONTENT[lang].contact;
---

<BaseLayout lang={lang} path="/contact" title={t.title} description={t.subtitle}>
  <section class="section-wrap pt-16">
    <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
      <article class="glass-card rounded-[2rem] p-8 md:p-10">
        <h1 class="text-4xl text-slate-900">{t.title}</h1>
        <p class="mt-4 text-sm leading-7 text-slate-700">{t.subtitle}</p>

        <form id="contact-form" class="mt-8 space-y-4" method="post" action="/api/contact/submit">
          <input type="hidden" name="lang" value={lang} />
          <input type="text" name="honeypot" class="hidden" tabindex="-1" autocomplete="off" />

          <label class="block text-sm font-semibold text-slate-700">
            {t.form.fullName}
            <input required name="fullName" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3" />
          </label>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="block text-sm font-semibold text-slate-700">
              {t.form.email}
              <input required type="email" name="email" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3" />
            </label>

            <label class="block text-sm font-semibold text-slate-700">
              {t.form.phone}
              <input required name="phone" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3" />
            </label>
          </div>

          <label class="block text-sm font-semibold text-slate-700">
            {t.form.preferredLanguage}
            <select name="preferredLanguage" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3">
              <option value="tr">Turkce</option>
              <option value="en">English</option>
              <option value="es">Espanol</option>
            </select>
          </label>

          <label class="block text-sm font-semibold text-slate-700">
            {t.form.subject}
            <input required name="subject" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3" />
          </label>

          <label class="block text-sm font-semibold text-slate-700">
            {t.form.message}
            <textarea required name="message" rows={6} class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3"></textarea>
          </label>

          <label class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white/80 p-4 text-xs text-slate-700">
            <input required type="checkbox" name="consent" class="mt-1" />
            <span>{t.form.consent}</span>
          </label>

          <button type="submit" class="cta-primary w-full">{t.form.send}</button>
          <p id="contact-feedback" class="text-sm"></p>
        </form>
      </article>

      <aside class="space-y-5">
        <div class="glass-card rounded-2xl p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Phone</p>
          <a class="mt-2 block text-sm font-semibold text-brand-700" href={`tel:${OFFICE_INFO.phone}`}>{OFFICE_INFO.phone}</a>
        </div>

        <div class="glass-card rounded-2xl p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Email</p>
          <a class="mt-2 block text-sm font-semibold text-brand-700" href={`mailto:${OFFICE_INFO.email}`}>{OFFICE_INFO.email}</a>
        </div>

        <div class="glass-card rounded-2xl p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">LinkedIn</p>
          <a class="mt-2 block text-sm font-semibold text-brand-700" target="_blank" href={OFFICE_INFO.linkedin}>Profile</a>
        </div>

        <div class="glass-card rounded-2xl p-6 text-sm leading-7 text-slate-700">
          <p><strong>{OFFICE_INFO.istanbul.label}:</strong> {OFFICE_INFO.istanbul.address}</p>
          <p class="mt-3"><strong>{OFFICE_INFO.madrid.label}:</strong> {OFFICE_INFO.madrid.address}</p>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const feedback = document.getElementById('contact-feedback');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      feedback.textContent = '';
      const formData = new FormData(form);

      const response = await fetch('/api/contact/submit', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();
      if (result.ok) {
        form.reset();
        feedback.textContent = result.message;
        feedback.className = 'text-sm text-green-700';
      } else {
        feedback.textContent = result.message;
        feedback.className = 'text-sm text-red-700';
      }
    });
  </script>
</BaseLayout>
